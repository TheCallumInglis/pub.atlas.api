# Database
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/pubatlas
QUARKUS_DATASOURCE_USERNAME=pubatlas
QUARKUS_DATASOURCE_PASSWORD=change-me

# Flyway Migrations
QUARKUS_FLYWAY_MIGRATE_AT_START=true

# (Very) Basic Auth Implementation
APP_API_KEY=some-long-secret

# CORS
CORS_ORIGINS=https://pub-atlas-ui
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=accept,authorization,content-type,x-api-key
